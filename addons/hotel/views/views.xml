<odoo>
  <data>

    <record model="ir.ui.view" id="view_booking_list">
      <field name="name">hotel.booking.list</field>
      <field name="model">hotel.booking</field>
      <field name="arch" type="xml">
        <list decoration-danger="state == 'cancel'" decoration-success="state == 'confirm'">
          <field name="booking_code"/>
          <field name="check_in"/>
          <field name="check_out"/>
        </list>
      </field>
    </record>

    <record model="ir.ui.view" id="view_booking_form">
      <field name="name">hotel.booking.form</field>
      <field name="model">hotel.booking</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <div class="oe_title">
                <h1>
                    <field name="booking_code"/>
                </h1>
            </div>

            <group>
              <group string="Datos Estancia">
                <field name="check_in"/>
                <field name="check_out"/>
              </group>
              <group string="Cliente">
                <field name="guest_id"/>
              </group>
            </group>

            <notebook>
                <page string="Servicios Extra">
                    </page>
            </notebook>

          </sheet>
        </form>
      </field>
    </record>

    <record model="ir.actions.act_window" id="action_booking">
      <field name="name">Reservas</field>
      <field name="res_model">hotel.booking</field>
      <field name="view_mode">list,form</field>
    </record>

    <menuitem name="Hotel" id="menu_hotel_root"/>
    <menuitem name="Booking" id="hotel.booking" parent="hotel.menu_hotel_root" action="action_booking"/>
    </data>
</odoo>